# Application
APP_NAME=LegalLink
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL
POSTGRES_USER=legallink
POSTGRES_PASSWORD=legallink
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legallink

# Document storage
STORAGE_PATH=storage/documents
MAX_UPLOAD_SIZE_MB=25
ALLOWED_MIME_TYPES=application/pdf
