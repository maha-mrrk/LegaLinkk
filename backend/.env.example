# Application
APP_NAME=LegalLink
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL (+ pgvector)
POSTGRES_USER=legallink
POSTGRES_PASSWORD=legallink
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legallink

# Document storage
STORAGE_PATH=storage/documents
MAX_UPLOAD_SIZE_MB=25
ALLOWED_MIME_TYPES=application/pdf

# OCR / extraction pipeline
OCR_ENABLED=true
# PaddleOCR language: en | french | arabic (and other PaddleOCR codes)
OCR_LANG=en
OCR_MIN_CHARS_PER_PAGE=30
OCR_RENDER_SCALE=2.0

# Chunking (RAG preprocessing)
CHUNK_SIZE=900
CHUNK_OVERLAP=175

# Semantic indexing (pgvector + embeddings)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_FALLBACK_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=8
EMBEDDING_CACHE_DIR=/root/.cache/fastembed
# First index downloads the ONNX model and can take several minutes.
AUTO_INDEX_ON_PROCESS=true
